{
  "name": "grok-desktop",
  "version": "0.0.11",
  "private": true,
  "description": "A product-grade desktop workspace for official Grok and SpaceXAI services",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "dev": "corepack pnpm --filter @grok-desktop/desktop dev",
    "dev:web": "corepack pnpm --filter @grok-desktop/desktop dev:web",
    "dev:cdp": "corepack pnpm --filter @grok-desktop/desktop dev:cdp",
    "build:windows-daemon": "corepack pnpm --filter @grok-desktop/desktop build:windows-daemon",
    "build:windows-service": "corepack pnpm --filter @grok-desktop/desktop build:windows-service",
    "build:dev-daemon": "corepack pnpm --filter @grok-desktop/desktop build:dev-daemon",
    "package:windows": "corepack pnpm --filter @grok-desktop/desktop package:windows",
    "package:linux": "corepack pnpm --filter @grok-desktop/desktop package:linux",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives --ignore-pattern apps/desktop/electron/generated",
    "build": "corepack pnpm -r build",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "corepack pnpm -r test && node --test scripts/*.test.mjs",
    "test:e2e:electron": "corepack pnpm --filter @grok-desktop/desktop test:e2e:electron",
    "test:rust": "cargo test --workspace",
    "check:rust": "cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings && cargo test --workspace",
    "check": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm build && corepack pnpm check:rust",
    "release:sync-version": "node scripts/sync-release-version.mjs",
    "release:check-version": "node scripts/sync-release-version.mjs --check"
  },
  "devDependencies": {
    "oxlint": "1.73.0"
  }
}
