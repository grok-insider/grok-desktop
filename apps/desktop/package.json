{
  "name": "@grok-desktop/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "cross-env VITE_BROWSER_PREVIEW=true vite --host 127.0.0.1",
    "dev:cdp": "node scripts/dev-cdp.mjs",
    "electron:watch": "tsc -p tsconfig.electron.build.json --watch --preserveWatchOutput",
    "electron:launch": "node scripts/launch-electron.mjs",
    "build": "vite build && node -e \"require('node:fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.build.json",
    "start": "electron .",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run && node --test scripts/*.test.mjs && pnpm test:assets",
    "test:assets": "node assets/tray/validate-assets.mjs",
    "test:e2e:electron": "node scripts/electron-cdp-smoke.mjs",
    "test:watch": "vitest",
    "generate:proto": "buf generate --template buf.gen.yaml",
    "build:windows-daemon": "node scripts/build-windows-daemon.mjs",
    "build:windows-service": "node scripts/build-windows-service.mjs",
    "build:dev-daemon": "cargo build -p grok-daemon --features debug-acp-descriptor",
    "package:windows": "pnpm build && node scripts/package-windows.mjs",
    "package:linux": "node scripts/package-linux.mjs",
    "release:update-manifest": "node scripts/generate-update-manifest.mjs"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.1",
    "@fontsource-variable/ibm-plex-sans": "5.2.8",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-scroll-area": "1.2.14",
    "@radix-ui/react-separator": "1.1.11",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.3.3",
    "@radix-ui/react-tooltip": "1.2.12",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.18.1",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "1.71.0",
    "@electron/fuses": "2.1.3",
    "@electron/packager": "20.0.2",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "cross-env": "10.1.0",
    "electron": "43.1.0",
    "electron-windows-msix": "2.0.4",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.2",
    "ts-proto": "2.12.0",
    "tw-animate-css": "1.4.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wait-on": "9.0.10"
  }
}
