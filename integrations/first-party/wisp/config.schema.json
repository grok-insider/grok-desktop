{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.grok.desktop/integrations/desktop.grok.wisp/config-v1.schema.json",
  "title": "Wisp managed integration configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "target": {
      "const": "nested",
      "default": "nested"
    },
    "approval": {
      "enum": ["confirm-risky", "confirm-each"],
      "default": "confirm-risky"
    },
    "maxInstances": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4,
      "default": 1
    },
    "allowGuestExec": {
      "const": false,
      "default": false
    },
    "telemetryContext": {
      "type": "boolean",
      "default": false
    }
  }
}
