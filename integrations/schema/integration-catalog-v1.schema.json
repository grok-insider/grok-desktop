{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.grok.desktop/integrations/integration-catalog-v1.schema.json",
  "title": "Grok Desktop managed integration catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "revision", "publisherId", "signature", "bundles"],
  "properties": {
    "version": { "const": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "publisherId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9.-]+$",
      "maxLength": 128
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "keyId", "value"],
      "properties": {
        "algorithm": { "const": "ed25519" },
        "keyId": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._:-]{1,128}$"
        },
        "value": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/]{86}==$"
        }
      }
    },
    "bundles": {
      "type": "array",
      "maxItems": 64,
      "items": { "$ref": "#/$defs/bundle" }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "maxLength": 64
    },
    "bundlePath": {
      "type": "string",
      "pattern": "^(?![/\\\\])(?![A-Za-z]:)(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$))[A-Za-z0-9._/-]+$",
      "maxLength": 260
    },
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "capability": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z0-9-]+)+$",
      "maxLength": 96
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size", "executable"],
      "properties": {
        "path": { "$ref": "#/$defs/bundlePath" },
        "sha256": { "$ref": "#/$defs/digest" },
        "size": { "type": "integer", "minimum": 1, "maximum": 67108864 },
        "executable": { "type": "boolean" }
      }
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "rootIndex",
        "bundlePath",
        "manifestPath",
        "manifestSha256",
        "allowedCapabilities",
        "files"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$",
          "maxLength": 128
        },
        "version": { "$ref": "#/$defs/semver" },
        "rootIndex": { "type": "integer", "minimum": 0, "maximum": 63 },
        "bundlePath": { "$ref": "#/$defs/bundlePath" },
        "manifestPath": { "$ref": "#/$defs/bundlePath" },
        "manifestSha256": { "$ref": "#/$defs/digest" },
        "allowedCapabilities": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/capability" }
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1024,
          "items": { "$ref": "#/$defs/file" }
        }
      }
    }
  }
}
